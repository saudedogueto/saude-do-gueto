{
  "expo": {
    "name": "SaudeDoGueto",
    "slug": "saude-do-gueto",
    "version": "1.1.0",
    "orientation": "portrait",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.saudedogueto.app",
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {},
    "newArchEnabled": false,
    "scheme": "saudedogueto",
    "extra": {
      "eas": {
        "projectId": "eb186d7d-18ce-49c0-8711-26e016fc7930"
      },
      "router": {
        "origin": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O Saúde do Gueto precisa da sua localização para marcar os pacientes no mapa.",
          "locationWhenInUsePermission": "O Saúde do Gueto precisa da sua localização para marcar os pacientes no mapa."
        }
      ]
    ],
    "owner": "saudedogueto"
  },
  "cli": {
    "appVersionSource": "remote"
  }
}
